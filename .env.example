# ============================================
# Nidari Framework - Environment overrides
# Primary configuration: res/conf/config.yaml
# Start API: python -m nidari --config-path res/conf/config.yaml
# Use .env only for secrets and deployment-specific overrides
# ============================================

# LLM secrets (override config.yaml llm.deepseek.api_key)
DEEPSEEK_API_KEY=your-api-key-here

# Database (override config.yaml database.url)
# DATABASE_URL=postgresql+asyncpg://agent:${POSTGRES_PASSWORD}@postgres:5432/agent_db

# MCP (JSON array string overrides config.yaml mcp.servers)
# MCP_ENABLED=true
# MCP_SERVERS=[{"name":"weather-mcp","command":"python3","args":["skills/weather_mcp_server.py"]}]

# Auth / BFF secrets (override config.yaml auth / bff sections)
# AUTH_ENABLED=true
# INTERNAL_TOKEN=change-me-internal-token
# BFF_JWT_SECRET=change-me-jwt-secret

# ============================================
# Docker deployment secrets — CHANGE FOR PRODUCTION
# ============================================
POSTGRES_PASSWORD=changeme
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana
