# ============================================
# Assistant Framework - Environment Variables
# Copy to .env and fill in your values
# ============================================

# LLM Configuration
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=2048
DEEPSEEK_TEMPERATURE=0.7

# Database (used by docker-compose)
# For local dev: DATABASE_URL=sqlite+aiosqlite:///./assistant.db
# For Docker: DATABASE_URL=postgresql+asyncpg://agent:${POSTGRES_PASSWORD}@postgres:5432/agent_db
DATABASE_URL=sqlite+aiosqlite:///./assistant.db
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# MCP Protocol
MCP_ENABLED=false
MCP_SERVERS=[]

# Auth (set to true for production)
AUTH_ENABLED=false

# Environment
ENV=development
DEBUG=true

# ============================================
# Docker deployment secrets — CHANGE ALL OF THESE FOR PRODUCTION
# ============================================
# PostgreSQL password (shared by postgres, agent-engine, bff)
POSTGRES_PASSWORD=changeme
# MinIO object storage credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana
# Internal service-to-service token (agent-engine <-> bff)
INTERNAL_TOKEN=change-me-internal-token
# JWT signing secret for BFF auth
BFF_JWT_SECRET=change-me-jwt-secret
