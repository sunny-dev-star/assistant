{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "今日对话量 (按渠道)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by(channel)(increase(agent_chat_requests_total[24h]))",
          "legendFormat": "{{channel}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "平均响应时间 (P95)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agent_chat_latency_seconds_bucket[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "max": 10,
          "min": 0
        }
      }
    },
    {
      "title": "LLM 今日费用 (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(agent_llm_cost_usd_total[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 4 }
      }
    },
    {
      "title": "LLM Token 消耗 (今日)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(increase(agent_llm_tokens_total{direction=\"input\"}[24h]))",
          "legendFormat": "Input"
        },
        {
          "expr": "sum(increase(agent_llm_tokens_total{direction=\"output\"}[24h]))",
          "legendFormat": "Output"
        }
      ]
    },
    {
      "title": "各租户今日对话量",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum by(tenant_id)(increase(agent_chat_requests_total[24h]))",
          "legendFormat": "{{tenant_id}}"
        }
      ]
    },
    {
      "title": "工具调用 TOP10",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by(tool_name)(increase(agent_tool_calls_total[24h])))",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },
    {
      "title": "响应延迟分布",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(agent_chat_latency_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(agent_chat_latency_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(agent_chat_latency_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "错误率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(agent_chat_request_errors_total[5m]) / rate(agent_chat_requests_total[5m])",
          "legendFormat": "{{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0 }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent-framework"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Agent Framework 运营概览",
  "uid": "agent-overview",
  "version": 1
}
